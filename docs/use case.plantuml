@startuml Wordle
left to right direction

actor Player as p

package Game {
    usecase "Play" as UC5
    usecase "Quit" as UC4
}

package InGame{
    usecase "Select letter" as UC1
    usecase "Try guess" as UC2
    usecase "Restart game" as UC3
}
p --> UC1
p --> UC2
p --> UC3
p --> UC4
p --> UC5
@enduml